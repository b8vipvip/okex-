[Unit]
Description=Recharge FastAPI Service
After=network.target

[Service]
User=root
WorkingDirectory=/opt/recharge-api/backend
EnvironmentFile=/opt/recharge-api/backend/.env
ExecStart=/opt/recharge-api/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
